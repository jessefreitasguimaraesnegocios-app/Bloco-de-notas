# --- Gemini (classificação ao salvar nota) ---
# Local: use GEMINI_API_KEY. Vercel: se não aceitar esse nome, use VITE_GEMINI_API_KEY (o Vite lê os dois).
GEMINI_API_KEY="MY_GEMINI_API_KEY"
# VITE_GEMINI_API_KEY="opcional-na-vercel"

# --- Supabase (Dashboard → Settings → API) ---
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# Checklist Supabase (painel):
# 1. SQL Editor: rodar supabase/migrations/00001_create_secrets_table.sql
# 2. Authentication → Providers → Google: Client ID + Secret (Google Cloud Console)
# 3. Authentication → URL Configuration:
#    - Site URL: http://localhost:3000 (dev) e https://seu-app.vercel.app (produção)
#    - Redirect URLs: mesmas URLs + https://seu-app.vercel.app/** e http://localhost:3000/**
# 4. Realtime: a migration inclui ALTER PUBLICATION supabase_realtime ADD TABLE secrets

# APP_URL (opcional, legado)
APP_URL="MY_APP_URL"

