{
  "entities": {
    "Secret": {
      "title": "Secret Note",
      "description": "A sensitive note containing a password, seed, key, or general information.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The title or label for the secret."
        },
        "content": {
          "type": "string",
          "description": "The actual sensitive content."
        },
        "type": {
          "type": "string",
          "description": "The type of secret (e.g., 'password', 'seed', 'key', 'other')."
        },
        "category": {
          "type": "string",
          "description": "AI-identified category or purpose."
        },
        "uid": {
          "type": "string",
          "description": "The owner's user ID."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the secret was created."
        }
      },
      "required": ["content", "uid", "createdAt"]
    }
  },
  "firestore": {
    "secrets": {
      "schema": "Secret",
      "description": "Collection of user secrets and sensitive notes."
    }
  }
}
